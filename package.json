{
  "name": "devlens-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "DevLens workspace for the browser toolbar package and the upcoming local MCP bridge.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @littleee/devpilot",
    "test": "npm run build",
    "check": "npm run check --workspace @littleee/devpilot"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.1.1",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "typescript": "^5.1.3"
  }
}
