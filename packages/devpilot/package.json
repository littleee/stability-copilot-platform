{
  "name": "@littleee/devpilot",
  "version": "0.2.0",
  "description": "A page-native annotation toolbar for collecting UI feedback and exporting it for AI-assisted code changes.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/littleee/stability-copilot-platform.git",
    "directory": "packages/devpilot"
  },
  "homepage": "https://github.com/littleee/stability-copilot-platform/tree/main/packages/devpilot",
  "bugs": {
    "url": "https://github.com/littleee/stability-copilot-platform/issues"
  },
  "keywords": [
    "annotation",
    "browser-toolbar",
    "feedback",
    "react",
    "ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json && node ./scripts/build-esm-wrapper.mjs",
    "check": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
